# =============================================================================
# GoMotarCar — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gomotarcar

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Razorpay (Payment Gateway) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ─── Firebase (Push Notifications) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=gomotarcar-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gomotarcar.iam.gserviceaccount.com

# ─── AWS S3 (File Uploads) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=gomotarcar-uploads

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@gomotarcar.com
SMTP_PASS=xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@gomotarcar.com

# ─── Encryption (PII at rest) ─────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-to-a-secure-32-char-key
ENCRYPTION_IV=change-this-16-char

# ─── Socket.io ────────────────────────────────────────────────────────────────
SOCKET_PORT=5000
SOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SOCKET_PING_TIMEOUT=30000
SOCKET_PING_INTERVAL=15000
SOCKET_MAX_BUFFER=1000000
SOCKET_MAX_PAYLOAD=1000000
SOCKET_IDLE_TIMEOUT=7200000

# ─── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_PANEL_URL=http://localhost:3000
