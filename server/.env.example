# ============================================================
# GoMotarCar Server — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp server/.env.example server/.env
# ============================================================

# ---- Node Environment ----
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ---- MongoDB (REQUIRED) ----
MONGODB_URI=mongodb://localhost:27017/gomotarcar

# ---- JWT Authentication (REQUIRED) ----
# Generate with: openssl rand -base64 64
JWT_SECRET=your-64-char-random-secret-here
JWT_REFRESH_SECRET=your-64-char-random-refresh-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ---- Firebase Cloud Messaging ----
# Required for push notifications. Get from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=gomotarcar-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@gomotarcar.iam.gserviceaccount.com

# ---- Razorpay Payment Gateway ----
# Required for payment processing. Get from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxx

# ---- AWS S3 / DigitalOcean Spaces ----
# Required for file uploads. Create an S3 bucket or DO Space.
S3_ACCESS_KEY_ID=AKIAxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxx
S3_BUCKET=gomotarcar-uploads
S3_REGION=ap-south-1
S3_ENDPOINT=                          # Optional: for custom S3-compatible endpoints

# ---- Redis ----
# Required for caching, queues, and Socket.IO adapter
REDIS_URL=redis://localhost:6379

# ---- SMS (Twilio) ----
# Required for SMS notifications (OTP, alerts)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ---- Email (SMTP) ----
# Optional: for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@gomotarcar.com

# ---- Encryption ----
# For encrypting sensitive data at rest. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key
ENCRYPTION_IV=your-32-char-hex-initialization-vector

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://admin.gomotarcar.com

# ---- Admin Panel URL ----
ADMIN_PANEL_URL=http://localhost:3000

# ---- Sentry (Error Tracking) ----
# Uncomment and fill in to enable error tracking
# SENTRY_DSN=https://<your-dsn>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
